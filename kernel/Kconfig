menu "KernelSU"

config KSU
	select SECURITY_SELINUX
	select SECCOMP
	select EXT4_FS
	select KEYS
	bool "KernelSU function support"
	default y
	help
	  Enable kernel-level root privileges on Android System.

config KSU_DEBUG
	bool "KernelSU debug mode"
	depends on KSU
	default n
	help
	  Enable KernelSU debug mode.

endmenu
